
# Titan Stack — Environment Variables

# ──────────────────────────────────────────────────────────────
# Node.js REST API (The Bridge)
# ──────────────────────────────────────────────────────────────
# URL of your custom Node.js backend server
VITE_API_URL=http://localhost:4000

# Set to "true" once your Node.js server is running.
# While false, all API calls are safe stubs (app works fully offline).
VITE_BACKEND_READY=false

# ──────────────────────────────────────────────────────────────
# AI Features (Google Gemini)
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
